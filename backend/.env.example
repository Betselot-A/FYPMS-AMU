# ============================================================
# Environment Variables — Copy to .env and fill in values
# ============================================================

PORT=5000
# If you don't have MongoDB locally, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/fyp_management?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30d
NODE_ENV=development


# Development-only demo accounts (set to true to disable auto-seeding)
DISABLE_DEMO_SEED=false

# File upload directory (relative to project root)
UPLOAD_DIR=uploads
